{
  "name": "my-app",
  "version": "1.0.50",
  "scripts": {
    "test": "bun test --env-file=env/.env",
    "dev": "bun --env-file=env/.env run --watch src/index.tsx",
    "prod": "bun --env-file=env/.env src/index.tsx",
    "prod:down": "taskkill /F /IM bun.exe",
    "docker:up": "docker compose -f src/db/compose.yml --env-file env/.env up -d",
    "docker:down": "docker compose -f src/db/compose.yml --env-file env/.env down",
    "docker:logs": "docker compose -f src/db/compose.yml --env-file env/.env logs -f",
    "docker:delete": "docker compose -f src/db/compose.yml --env-file env/.env down -v --rmi all --remove-orphans",
    "db:seed": "bun --env-file=env/.env src/db/seed.ts",
    "db:seed:all": "bun run db:seed src/db/seed_rewards.sql && bun run db:seed src/db/seed_ranking.sql && bun run db:seed src/db/seed_insignias.sql && bun run db:seed src/db/seed_pevs.sql"
  },
  "dependencies": {
    "@elysia/html": "^1.4.1",
    "@elysiajs/cors": "^1.4.2",
    "@kitajs/ts-html-plugin": "^4.1.4",
    "@paulmillr/qr": "^0.3.0",
    "better-auth": "^1.6.18",
    "elysia": "latest",
    "html5-qrcode": "^2.3.8",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "bun-types": "latest",
    "typed-htmx": "^0.3.1",
    "@types/bun": "latest"
  },
  "module": "src/index.tsx",
  "type": "module",
  "private": true,
  "peerDependencies": {
    "typescript": "^5"
  }
}