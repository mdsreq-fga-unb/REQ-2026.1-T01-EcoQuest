    "@paulmillr/qr": "^0.3.0",
    "better-auth": "^1.6.18",
    "elysia": "latest",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "bun-types": "latest",
    "typed-htmx": "^0.3.1",
    "@types/bun": "latest"
  },
  "module": "src/index.js",
